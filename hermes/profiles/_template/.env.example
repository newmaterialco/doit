# Per-user Hermes profile .env.
# Copy to ~/.hermes/profiles/<user>/.env on the VM and fill in real values.

# --- Hermes API server (the runner connects here over loopback) ---
API_SERVER_ENABLED=true
API_SERVER_HOST=127.0.0.1
API_SERVER_PORT=8643                # MUST be unique per user (8643, 8644, ...)
API_SERVER_KEY=replace-with-random-secret-per-user

# --- Composio (managed OAuth for Gmail, Calendar, etc.) ---
COMPOSIO_API_KEY=YOUR_COMPOSIO_API_KEY
COMPOSIO_ENTITY_ID=replace-with-this-users-supabase-uuid

# --- Model provider ---
# Nous Portal is set up once via `hermes setup --portal` and is shared across
# profiles, so nothing needs to go here for the default case. The runner writes
# Doit's global provider key here when the user picks a direct provider such as
# OpenAI, Anthropic, or OpenRouter from Settings.

# --- Browserbase (managed browser automation) ---
# Browserbase credentials are normally stored once in ~/.hermes/.env so every
# profile can use Hermes' browser toolset and the browse.sh CLI. Keep these
# profile-level placeholders commented unless you intentionally want to override
# the global values for this profile.
# BROWSERBASE_API_KEY=YOUR_BROWSERBASE_API_KEY
# BROWSERBASE_PROJECT_ID=your-browserbase-project-id
